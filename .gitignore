# Workspace-level artifacts
worldweaver_artifacts/
legacy_git/
working_*.mp4
working_*.png
**/.git.legacy/

# Editor / OS noise
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/

# Root-level virtualenvs
.venv/
venv/
env/
ENV/

# Live shard runtime state
shards/*/.env
shards/*/.env.*
shards/*/node.json
shards/*/hearth-host.json
shards/*/hearth-host/identity/transport.key
shards/*/db/
shards/*/data/
shards/*/residents/
worldweaver_engine/data/city_drafts/
# Frozen experiment + resident archives: kept on disk for restore, never tracked source
shards/*/_*frozen*/

# Allow shard docs and compose manifests
!shards/*/README.md
!shards/*/.gitignore
!shards/*/docker-compose.yml

# prune/ holds the PUBLIC work-item ledger AND local strategy/scratch. Track the ledger
# (majors/minors/publication/harness/v6_docs), the project anchors (VISION/ROADMAP/README), and the CI
# warning baseline; keep loose strategy/planning docs + history/ local by default.
/prune/*
!/prune/majors/
# major 79 (funding strategy) kept private — keeper decision 2026-06-16
/prune/majors/79-*
!/prune/minors/
!/prune/publication/
!/prune/publication/README.md
!/prune/publication/majors/
!/prune/publication/majors/*.md
!/prune/publication/minors/
!/prune/publication/minors/*.md
!/prune/harness/
!/prune/v6_docs/
!/prune/VISION.md
!/prune/ROADMAP.md
!/prune/README.md
!/prune/ARCHITECTURAL_PLAN_OF_ATTACK.2026-07-14.md

# Root-level scratch only (csv/md snapshots). Anchored with a leading slash so it
# does NOT swallow real nested test suites (ww_agent/tests, worldweaver_engine/tests).
/tests/
# Local-only research/inspiration scratch (not part of the repo)
inspiration/

# Python caches (previously masked under the over-broad `tests/` rule)
__pycache__/
*.py[cod]

# Local familiar runtime data (the soul + code are tracked; the lived state is not)
ww_agent/familiar/*/memory/
ww_agent/familiar/*/workshop/
ww_agent/familiar/*/state.json
ww_agent/familiar/*/whispers.jsonl
ww_agent/familiar/*/voice.jsonl
ww_agent/familiar/*/identity/resident_id.txt
ww_agent/familiar/*/contact-sheets/
ww_agent/familiar/*/letters/
ww_agent/familiar/overnight-report-*.txt

# Substrate-era resident runtime memory (projections/ledger; the old patterns only caught loop-era files)
ww_agent/residents/*/memory/

# Reviewer bundle: a derived mirror of src/ + local reviewer prose (regenerate via sync-bundle.sh, minor 49).
# Kept local like prune/; the FileScope familiars read it on disk regardless of git.
ww_agent/familiar/architecture-bundle/
# Loose dups of the bundle's diagram at the familiar/ root
ww_agent/familiar/substrate-architecture.*

# Scratch diagnostic scripts — kept local until formalized (minors 47/50)
ww_agent/scripts/_*.py
ww_agent/scripts/_*.sh

# OpenRouter activity exports / analysis inputs (kept local)
openrouter_activity_*.csv
openrouter-activity-*.csv

# Claude Code local session state (per-machine, never shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Tauri build artifacts for the familiar portrait
ww_agent/familiar/portrait/src-tauri/target/
ww_agent/familiar/portrait/src-tauri/gen/
ww_agent/familiar/portrait/src-tauri/Cargo.lock
ww_agent/familiar/portrait/node_modules/

# Mr. Review working artifacts (not source). Root-anchored: the LOCAL workspace and the
# local tarball store are ignored, but the PUBLIC published rounds in
# research/review-bundle/ (pushed for the cold reviewer) must stay tracked.
/review-bundle/
/review-archive/

# My personal writing for this project
being-wrong-well/

# research/ is PUBLIC + tracked (run records, ledgers, artifacts so reviews are cold-verifiable).
# Backstop only — secret-free by construction; never let a stray secret file slip in.
research/**/.env
research/**/*.key
research/**/secrets*

# persistent experiment scratch (recordings/parity) — never /tmp (reboot wipes it)
.runs/

# understand-anything plugin data (generated knowledge graphs)
.ua/
.understand-anything/
.understandignore

# uv-generated lockfiles (toolchain artifact; requirements.txt / pyproject are canonical)
uv.lock
