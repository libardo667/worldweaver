# Core LLM provider configuration
# Required for live LLM-powered runtime: set at least one API key below.
OPENROUTER_API_KEY=
LLM_API_KEY=
OPENAI_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-r1
EMBEDDING_MODEL=openai/text-embedding-3-small

# Runtime tuning
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2500
LLM_TIMEOUT_SECONDS=15
LLM_RETRIES=2

# Semantic storylet selection tuning
# Higher floor => broader/more diverse picks.
LLM_SEMANTIC_FLOOR_PROBABILITY=0.05
# Higher penalty => less immediate repetition.
LLM_RECENCY_PENALTY=0.3

# Optional database override
DW_DB_PATH=worldweaver.db

# API cache behavior
STATE_MANAGER_CACHE_MAX_SIZE=500
STATE_MANAGER_CACHE_TTL_SECONDS=3600
NAVIGATOR_CACHE_MAX_SIZE=32
NAVIGATOR_CACHE_TTL_SECONDS=3600

# Optional client-only overrides can go in `client/.env.local`.
