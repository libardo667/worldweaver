{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cinder",
  "version": "0.1.0",
  "identifier": "org.worldweaver.cinder",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cinder",
        "label": "cinder",
        "width": 360,
        "height": 640,
        "minWidth": 260,
        "minHeight": 380,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
