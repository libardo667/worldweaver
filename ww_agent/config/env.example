# worldweaver-agent environment
# Copy to .env in ww_agent/ and fill in your values.
# Load with: export $(grep -v '^#' .env | xargs)

# Required: LLM API key (OpenRouter or any OpenAI-compatible provider)
WW_INFERENCE_KEY=

# WorldWeaver server base URL (no trailing slash, no /api suffix)
WW_SERVER_URL=http://localhost:8000

# LLM provider
WW_INFERENCE_URL=https://openrouter.ai/api/v1
WW_INFERENCE_MODEL=google/gemini-flash-2.0-lite

# Residents directory (relative to ww_agent/ or absolute)
WW_RESIDENTS_DIR=./residents

# Logging
WW_LOG_LEVEL=INFO

# Private exact inference evidence (default off). Enable only for a declared, bounded
# diagnostic that may write memory/prompt_traces.jsonl inside each resident's home.
WW_PROMPT_TRACE=0

# Doula: world-watching daemon that spawns new residents from narrative evidence
# WW_DOULA=true
# WW_DOULA_MODEL=google/gemini-flash-2.0-lite
